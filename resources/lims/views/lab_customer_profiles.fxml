<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1100.0"
            prefHeight="650.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.LabCustomerProfilesController"
            styleClass="dashboard-background">

    <left>
        <VBox spacing="18"
              prefWidth="230"
              styleClass="admin-sidebar">

            <children>
                <VBox spacing="3">
                    <children>
                        <Label text="SANTÉ"
                               styleClass="sidebar-brand-title" />

                        <Label text="DIAGNOSTICS LIMS"
                               styleClass="sidebar-brand-subtitle" />
                    </children>
                </VBox>

                <Region prefHeight="18" />

                <Button text="Dashboard"
                        onAction="#backToDashboard"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Customer Profiles"
                        onAction="#openCustomerProfiles"
                        prefWidth="198"
                        styleClass="sidebar-menu-button-active" />

                <Button text="Test Request Queue"
                        onAction="#openLabRequestQueue"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Sample Tracking"
                        onAction="#openSampleTracking"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Result Upload &amp; Validation"
                        onAction="#openResultUploadValidation"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Region VBox.vgrow="ALWAYS" />

                <Button text="Logout"
                        onAction="#handleLogout"
                        prefWidth="198"
                        styleClass="admin-logout-button" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox spacing="20"
              alignment="CENTER_LEFT"
              styleClass="top-bar">

            <children>
                <Label text="Customer Profiles"
                       styleClass="dashboard-title" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="← Back to Dashboard"
                        onAction="#backToDashboard"
                        styleClass="back-dashboard-button" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="22"
              styleClass="admin-main-area">

            <children>
                <VBox spacing="8"
                      styleClass="admin-hero-card">

                    <children>
                        <Label text="Create Customer Account"
                               styleClass="admin-hero-title" />

                        <Label text="Create customer profiles for patients who are registered by laboratory staff. The customer will be required to change their temporary password at first login."
                               wrapText="true"
                               styleClass="admin-hero-subtitle" />
                    </children>
                </VBox>

                <VBox alignment="CENTER"
                      spacing="15"
                      styleClass="form-card">

                    <children>
                        <Label text="New Customer Profile"
                               styleClass="section-heading" />

                        <VBox spacing="6">
                            <children>
                                <Label text="Full Name"
                                       styleClass="input-label" />

                                <TextField fx:id="fullNameField"
                                           promptText="Enter customer full name"
                                           prefWidth="360"
                                           styleClass="auth-input" />
                            </children>
                        </VBox>

                        <VBox spacing="6">
                            <children>
                                <Label text="Email Address"
                                       styleClass="input-label" />

                                <TextField fx:id="emailField"
                                           promptText="Enter customer email"
                                           prefWidth="360"
                                           styleClass="auth-input" />
                            </children>
                        </VBox>

                        <VBox spacing="6">
                            <children>
                                <Label text="Temporary Password"
                                       styleClass="input-label" />

                                <PasswordField fx:id="temporaryPasswordField"
                                               promptText="Enter temporary password"
                                               prefWidth="360"
                                               styleClass="auth-input" />
                            </children>
                        </VBox>

                        <Label fx:id="messageLabel"
                               text=""
                               wrapText="true"
                               styleClass="error-label" />

                        <Button text="Create Customer Account"
                                onAction="#handleCreateCustomer"
                                prefWidth="360"
                                styleClass="primary-button" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

</BorderPane>