<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lims.controllers.CustomerRegisterController">

    <children>
        <Label layoutX="220" layoutY="40" text="Customer Registration" />

        <Label layoutX="120" layoutY="100" text="Full Name:" />
        <TextField fx:id="fullNameField" layoutX="250" layoutY="95" prefWidth="220" />

        <Label layoutX="120" layoutY="150" text="Email:" />
        <TextField fx:id="emailField" layoutX="250" layoutY="145" prefWidth="220" />

        <Label layoutX="120" layoutY="200" text="Password:" />
        <PasswordField fx:id="passwordField" layoutX="250" layoutY="195" prefWidth="220" />

        <Label layoutX="120" layoutY="250" text="Confirm Password:" />
        <PasswordField fx:id="confirmPasswordField" layoutX="250" layoutY="245" prefWidth="220" />

        <Label fx:id="messageLabel" layoutX="180" layoutY="285" />

        <Button layoutX="250" layoutY="320" onAction="#registerCustomer" prefWidth="120" text="Register" />
    </children>
</AnchorPane>
