<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="lims.controllers.TestBuilderController"
            prefWidth="1100"
            prefHeight="650"
            styleClass="dashboard-background">

    <left>
        <VBox spacing="18"
              prefWidth="230"
              styleClass="admin-sidebar">

            <children>
                <VBox spacing="3">
                    <children>
                        <Label text="SANTÉ"
                               styleClass="sidebar-brand-title" />

                        <Label text="DIAGNOSTICS LIMS"
                               styleClass="sidebar-brand-subtitle" />
                    </children>
                </VBox>

                <Region prefHeight="18" />

                <Button text="Dashboard"
                        onAction="#goBackToDashboard"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="User Management"
                        onAction="#openUserManagement"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Custom Test Builder"
                        onAction="#openTestBuilder"
                        prefWidth="198"
                        styleClass="sidebar-menu-button-active" />

                <Button text="Test Request Queue"
                        onAction="#openTestRequestQueue"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Audit Trail"
                        onAction="#openAuditTrail"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Region VBox.vgrow="ALWAYS" />

                <Button text="Logout"
                        onAction="#handleLogout"
                        prefWidth="198"
                        styleClass="admin-logout-button" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox spacing="20"
              alignment="CENTER_LEFT"
              styleClass="top-bar">

            <children>
                <Label text="Custom Test Builder"
                       styleClass="dashboard-title" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="← Back to Dashboard"
                        onAction="#goBackToDashboard"
                        styleClass="back-dashboard-button" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER"
              spacing="15"
              styleClass="form-card">

            <children>

                <Label text="Create Laboratory Test Type"
                       styleClass="section-heading" />

                <TextField fx:id="testNameField"
                           promptText="Test Name e.g. Full Blood Count"
                           prefWidth="340" />

                <ComboBox fx:id="categoryComboBox"
                          promptText="Select Category"
                          prefWidth="340" />

                <TextField fx:id="priceField"
                           promptText="Price e.g. 5000"
                           prefWidth="340" />

                <TextField fx:id="turnaroundTimeField"
                           promptText="Turnaround Time in Hours e.g. 24"
                           prefWidth="340" />

                <ComboBox fx:id="resultFormatComboBox"
                          promptText="Select Result Format"
                          prefWidth="340" />

                <Label fx:id="messageLabel"
                       text=""
                       styleClass="error-label" />

                <Button text="Create Test Type"
                        onAction="#handleCreateTestType"
                        prefWidth="340"
                        styleClass="primary-button" />

            </children>
        </VBox>
    </center>

</BorderPane>