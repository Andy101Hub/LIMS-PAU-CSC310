<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="900.0"
            prefHeight="560.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.ForgotPasswordController"
            styleClass="auth-background">

    <left>
        <VBox prefWidth="330"
              spacing="22"
              styleClass="auth-left-panel">

            <children>
                <VBox spacing="4">
                    <children>
                        <Label text="SANTÉ"
                               styleClass="brand-title" />

                        <Label text="DIAGNOSTICS LIMS"
                               styleClass="brand-subtitle" />
                    </children>
                </VBox>

                <Region prefHeight="60" />

                <Label text="Reset your password."
                       wrapText="true"
                       styleClass="hero-title" />

                <Label text="Customers can receive a temporary password by email. Lab Attendants must request a reset from the Super Admin."
                       wrapText="true"
                       styleClass="hero-text" />

                <Region VBox.vgrow="ALWAYS" />

                <Label text="Secure • Verified • Protected"
                       styleClass="hero-text" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER"
              styleClass="auth-background">

            <children>
                <VBox spacing="16"
                      prefWidth="410"
                      styleClass="auth-card">

                    <children>
                        <VBox spacing="4">
                            <children>
                                <Label text="Forgot Password"
                                       styleClass="auth-title" />

                                <Label text="Select your account type and enter your email."
                                       wrapText="true"
                                       styleClass="auth-subtitle" />
                            </children>
                        </VBox>

                        <VBox spacing="6">
                            <children>
                                <Label text="Account Type"
                                       styleClass="input-label" />

                                <ComboBox fx:id="roleComboBox"
                                          promptText="Select Customer or Lab Attendant"
                                          prefWidth="350"
                                          styleClass="auth-input" />
                            </children>
                        </VBox>

                        <VBox spacing="6">
                            <children>
                                <Label text="Email Address"
                                       styleClass="input-label" />

                                <TextField fx:id="emailField"
                                           promptText="Enter your account email"
                                           prefWidth="350"
                                           styleClass="auth-input" />
                            </children>
                        </VBox>

                        <Label fx:id="messageLabel"
                               text=""
                               wrapText="true"
                               styleClass="error-label" />

                        <Button text="Continue"
                                onAction="#handleForgotPassword"
                                prefWidth="350"
                                styleClass="primary-button" />

                        <Button text="Back to Login"
                                onAction="#backToLogin"
                                prefWidth="350"
                                styleClass="secondary-button" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

</BorderPane>