<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="900.0"
            prefHeight="560.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.EmailVerificationController"
            styleClass="auth-background">

    <left>
        <VBox prefWidth="330"
              spacing="22"
              styleClass="auth-left-panel">

            <children>
                <VBox spacing="4">
                    <children>
                        <Label text="SANTÉ"
                               styleClass="brand-title" />

                        <Label text="DIAGNOSTICS LIMS"
                               styleClass="brand-subtitle" />
                    </children>
                </VBox>

                <Region prefHeight="60" />

                <Label text="Verify your email."
                       wrapText="true"
                       styleClass="hero-title" />

                <Label text="Enter the verification code sent to your email before accessing your customer dashboard."
                       wrapText="true"
                       styleClass="hero-text" />

                <Region VBox.vgrow="ALWAYS" />

                <Label text="Secure • Verified • Trusted"
                       styleClass="hero-text" />
            </children>
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER"
              styleClass="auth-background">

            <children>
                <VBox spacing="16"
                      prefWidth="410"
                      styleClass="auth-card">

                    <children>
                        <VBox spacing="4">
                            <children>
                                <Label text="Email Verification"
                                       styleClass="auth-title" />

                                <Label fx:id="instructionLabel"
                                       text="Enter the code sent to your email."
                                       wrapText="true"
                                       styleClass="auth-subtitle" />
                            </children>
                        </VBox>

                        <VBox spacing="6">
                            <children>
                                <Label text="Verification Code"
                                       styleClass="input-label" />

                                <TextField fx:id="codeField"
                                           promptText="Enter 6-digit code"
                                           prefWidth="350"
                                           styleClass="auth-input" />
                            </children>
                        </VBox>

                        <Label fx:id="messageLabel"
                               text=""
                               wrapText="true"
                               styleClass="error-label" />

                        <Button text="Verify Email"
                                onAction="#handleVerifyCode"
                                prefWidth="350"
                                styleClass="primary-button" />

                        <Button text="Resend Code"
                                onAction="#handleResendCode"
                                prefWidth="350"
                                styleClass="secondary-button" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

</BorderPane>