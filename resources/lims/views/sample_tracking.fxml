<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1150.0"
            prefHeight="650.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.SampleTrackingController"
            styleClass="dashboard-background">

    <left>
        <VBox spacing="18"
              prefWidth="230"
              styleClass="admin-sidebar">

            <children>
                <VBox spacing="3">
                    <children>
                        <Label text="SANTÉ"
                               styleClass="sidebar-brand-title" />

                        <Label text="DIAGNOSTICS LIMS"
                               styleClass="sidebar-brand-subtitle" />
                    </children>
                </VBox>

                <Region prefHeight="18" />

                <Button text="Dashboard"
                        onAction="#backToDashboard"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />
                
                <Button text="Customer Profiles"
                        onAction="#openCustomerProfiles"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Test Request Queue"
                        onAction="#openLabRequestQueue"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Sample Tracking"
                        onAction="#openSampleTracking"
                        prefWidth="198"
                        styleClass="sidebar-menu-button-active" />

                <Button text="Result Upload &amp; Validation"
                        onAction="#openResultUploadValidation"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Region VBox.vgrow="ALWAYS" />

                <Button text="Logout"
                        onAction="#handleLogout"
                        prefWidth="198"
                        styleClass="admin-logout-button" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox spacing="20"
              alignment="CENTER_LEFT"
              styleClass="top-bar">

            <children>
                <Label text="Sample Lifecycle Tracking"
                       styleClass="dashboard-title" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="← Back to Dashboard"
                        onAction="#backToDashboard"
                        styleClass="back-dashboard-button" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="18"
              styleClass="admin-main-area">

            <children>
                <VBox spacing="8"
                      styleClass="admin-hero-card">

                    <children>
                        <Label text="Track Sample Progress"
                               styleClass="admin-hero-title" />

                        <Label text="Update each paid request from sample collection through processing, validation, and completion."
                               wrapText="true"
                               styleClass="admin-hero-subtitle" />
                    </children>
                </VBox>

                <VBox spacing="15"
                      styleClass="table-card">

                    <children>
                        <Label text="Paid Requests and Sample Status"
                               styleClass="section-heading" />

                        <TableView fx:id="requestTable"
                                   prefWidth="850"
                                   prefHeight="330">

                            <columns>
                                <TableColumn fx:id="requestIdColumn"
                                             text="Request ID"
                                             prefWidth="80" />

                                <TableColumn fx:id="customerNameColumn"
                                             text="Customer Name"
                                             prefWidth="145" />

                                <TableColumn fx:id="customerEmailColumn"
                                             text="Customer Email"
                                             prefWidth="180" />

                                <TableColumn fx:id="testNameColumn"
                                             text="Test Name"
                                             prefWidth="160" />

                                <TableColumn fx:id="paymentStatusColumn"
                                             text="Payment"
                                             prefWidth="100" />

                                <TableColumn fx:id="requestStatusColumn"
                                             text="Sample Status"
                                             prefWidth="150" />

                                <TableColumn fx:id="requestedAtColumn"
                                             text="Requested At"
                                             prefWidth="150" />
                            </columns>
                        </TableView>

                        <HBox spacing="15"
                              alignment="CENTER_LEFT">

                            <children>
                                <ComboBox fx:id="statusComboBox"
                                          promptText="Select New Status"
                                          prefWidth="230" />

                                <Button text="Update Sample Status"
                                        onAction="#handleUpdateStatus"
                                        prefWidth="220"
                                        styleClass="primary-button" />

                                <Button text="Refresh"
                                        onAction="#handleRefresh"
                                        prefWidth="140"
                                        styleClass="secondary-button" />

                                <Button text="Proceed to Result Upload"
                                        onAction="#openResultUploadValidation"
                                        prefWidth="220"
                                        styleClass="secondary-button" />
                            </children>
                        </HBox>

                        <Label fx:id="messageLabel"
                               text=""
                               wrapText="true"
                               styleClass="error-label" />
                    </children>
                </VBox>

                <VBox spacing="8"
                      styleClass="admin-hero-card">

                    <children>
                        <Label text="Lifecycle Order"
                               styleClass="admin-section-title" />

                        <Label text="Recommended order: PAID → SAMPLE_COLLECTED → PROCESSING → AWAITING_VALIDATION → VALIDATED → COMPLETED."
                               wrapText="true"
                               styleClass="admin-section-text" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

</BorderPane>