<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1100.0"
            prefHeight="620.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.ResultUploadValidationController"
            styleClass="dashboard-background">

    <left>
        <VBox spacing="18"
              prefWidth="230"
              styleClass="admin-sidebar">

            <children>
                <VBox spacing="3">
                    <children>
                        <Label text="SANTÉ"
                               styleClass="sidebar-brand-title" />

                        <Label text="DIAGNOSTICS LIMS"
                               styleClass="sidebar-brand-subtitle" />
                    </children>
                </VBox>

                <Region prefHeight="18" />

                <Button text="Dashboard"
                        onAction="#backToDashboard"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />
                
                <Button text="Customer Profiles"
                        onAction="#openCustomerProfiles"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Test Request Queue"
                        onAction="#openLabRequestQueue"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Sample Tracking"
                        onAction="#openSampleTracking"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Result Upload &amp; Validation"
                        onAction="#openResultUploadValidation"
                        prefWidth="198"
                        styleClass="sidebar-menu-button-active" />

                <Region VBox.vgrow="ALWAYS" />

                <Button text="Logout"
                        onAction="#handleLogout"
                        prefWidth="198"
                        styleClass="admin-logout-button" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox spacing="20"
              alignment="CENTER_LEFT"
              styleClass="top-bar">

            <children>
                <Label text="Result Upload &amp; Validation"
                       styleClass="dashboard-title" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="← Back to Dashboard"
                        onAction="#backToDashboard"
                        styleClass="back-dashboard-button" />
            </children>
        </HBox>
    </top>

    <center>
    <VBox spacing="12"
          styleClass="admin-main-area">

        <children>
            <VBox spacing="6"
                  styleClass="admin-hero-card">

                <children>
                    <Label text="Upload and Validate Patient Results"
                           styleClass="admin-hero-title" />

                    <Label text="Attach PDF reports and medical images to customer test requests. Results only become visible to customers after validation."
                           wrapText="true"
                           styleClass="admin-hero-subtitle" />
                </children>
            </VBox>

            <VBox spacing="10"
                  styleClass="table-card">

                <children>
                    <Label text="Requests Awaiting Result Upload or Validation"
                           styleClass="section-heading" />

                    <TableView fx:id="requestTable"
                               prefWidth="850"
                               prefHeight="220"
                               minHeight="220">

                        <columns>
                            <TableColumn fx:id="requestIdColumn"
                                         text="Request ID"
                                         prefWidth="95" />

                            <TableColumn fx:id="customerNameColumn"
                                         text="Customer Name"
                                         prefWidth="160" />

                            <TableColumn fx:id="customerEmailColumn"
                                         text="Customer Email"
                                         prefWidth="200" />

                            <TableColumn fx:id="testNameColumn"
                                         text="Test Name"
                                         prefWidth="170" />

                            <TableColumn fx:id="paymentStatusColumn"
                                         text="Payment"
                                         prefWidth="110" />

                            <TableColumn fx:id="requestStatusColumn"
                                         text="Request Status"
                                         prefWidth="160" />
                            
                            <TableColumn fx:id="requestedAtColumn"
                                         text="Requested At"
                                         prefWidth="150" />
                        </columns>
                    </TableView>

                    <HBox spacing="30"
                          alignment="CENTER_LEFT">

                        <children>
                            <VBox spacing="6">
                                <children>
                                    <Label text="Selected PDF Report:"
                                           styleClass="input-label" />

                                    <Label fx:id="pdfPathLabel"
                                           text="No PDF selected"
                                           wrapText="true"
                                           maxWidth="320"
                                           styleClass="admin-section-text" />

                                    <Button text="Choose PDF Report"
                                            onAction="#handleChoosePdf"
                                            prefWidth="180"
                                            styleClass="secondary-button" />
                                </children>
                            </VBox>

                            <VBox spacing="6">
                                <children>
                                    <Label text="Selected Medical Image:"
                                           styleClass="input-label" />

                                    <Label fx:id="imagePathLabel"
                                           text="No image selected"
                                           wrapText="true"
                                           maxWidth="320"
                                           styleClass="admin-section-text" />

                                    <Button text="Choose Medical Image"
                                            onAction="#handleChooseImage"
                                            prefWidth="190"
                                            styleClass="secondary-button" />
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <HBox spacing="15"
                          alignment="CENTER_LEFT">

                        <children>
                            <Button text="Upload Result Files"
                                    onAction="#handleUploadFiles"
                                    prefWidth="190"
                                    styleClass="primary-button" />

                            <Button text="Validate and Release Result"
                                    onAction="#handleValidateResult"
                                    prefWidth="240"
                                    styleClass="primary-button" />

                            <Button text="Refresh"
                                    onAction="#handleRefresh"
                                    prefWidth="130"
                                    styleClass="secondary-button" />
                        </children>
                    </HBox>

                    <Label fx:id="messageLabel"
                           text=""
                           wrapText="true"
                           styleClass="error-label" />
                </children>
            </VBox>
        </children>
    </VBox>
</center>
</BorderPane>