<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="lims.controllers.LoginController"
            prefWidth="980"
            prefHeight="620"
            styleClass="auth-background">

    <children>

        <!-- Left branding panel -->
        <VBox layoutX="0"
              layoutY="0"
              prefWidth="390"
              prefHeight="620"
              spacing="35"
              styleClass="auth-left-panel">

            <children>
                <VBox spacing="2">
                    <children>
                        <Label text="SANTÉ"
                               styleClass="brand-title" />
                        <Label text="DIAGNOSTICS"
                               styleClass="brand-subtitle" />
                    </children>
                </VBox>

                <VBox spacing="14">
                    <children>
                        <Label text="Accurate tests."
                               styleClass="hero-title" />
                        <Label text="Better health."
                               styleClass="hero-title" />
                        <Label text="Welcome to Santé Diagnostics Laboratory Information Management System."
                               wrapText="true"
                               prefWidth="280"
                               styleClass="hero-text" />
                    </children>
                </VBox>

                <Label text="Secure login • Test requests • Result access"
                       styleClass="hero-text" />
            </children>
        </VBox>

        <!-- Right login card -->
        <VBox layoutX="485"
              layoutY="72"
              prefWidth="390"
              prefHeight="470"
              spacing="16"
              styleClass="auth-card">

            <children>

                <VBox spacing="4">
                    <children>
                        <Label text="Welcome Back"
                               styleClass="auth-title" />
                        <Label text="Please sign in to your account"
                               styleClass="auth-subtitle" />
                    </children>
                </VBox>

                <VBox spacing="6">
                    <children>
                        <Label text="Email"
                               styleClass="input-label" />

                        <TextField fx:id="emailField"
                                   promptText="Enter your email"
                                   prefWidth="320"
                                   styleClass="auth-input" />
                    </children>
                </VBox>

                <VBox spacing="6">
                    <children>
                        <Label text="Password"
                               styleClass="input-label" />

                        <StackPane prefWidth="320">
                            <children>
                                <PasswordField fx:id="passwordField"
                                               promptText="Enter your password"
                                               prefWidth="320"
                                               styleClass="auth-input" />

                                <TextField fx:id="visiblePasswordField"
                                           promptText="Enter your password"
                                           prefWidth="320"
                                           visible="false"
                                           managed="false"
                                           styleClass="auth-input" />

                                <Button fx:id="togglePasswordButton"
                                        text="👁"
                                        onAction="#togglePasswordVisibility"
                                        StackPane.alignment="CENTER_RIGHT"
                                        styleClass="password-eye-button" />
                            </children>
                        </StackPane>
                    </children>
                </VBox>

                <HBox spacing="95">
                    <children>
                        <CheckBox text="Remember me" />
                        <Button text="Forgot password?"
                                styleClass="link-button" />
                    </children>
                </HBox>

                <Label fx:id="messageLabel"
                       text=""
                       styleClass="error-label" />

                <Button text="Sign In"
                        onAction="#handleLogin"
                        prefWidth="320"
                        styleClass="primary-button" />

                <Label text="Or sign in as"
                       styleClass="auth-subtitle" />

                <HBox spacing="10">
                    <children>
                        <Button text="Super Admin"
                                prefWidth="100"
                                styleClass="secondary-button" />
                        <Button text="Lab Attendant"
                                prefWidth="105"
                                styleClass="secondary-button" />
                        <Button text="Customer"
                                prefWidth="100"
                                styleClass="secondary-button" />
                    </children>
                </HBox>

                <HBox spacing="5" alignment="CENTER">
                    <children>
                        <Label text="Don't have an account?"
                               styleClass="auth-subtitle" />

                        <Button text="Create one"
                                onAction="#openCustomerRegister"
                                styleClass="link-button" />
                    </children>
                </HBox>

            </children>
        </VBox>

    </children>
</AnchorPane>