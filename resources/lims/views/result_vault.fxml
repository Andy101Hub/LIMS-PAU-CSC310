<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1100.0"
            prefHeight="650.0"
            xmlns="http://javafx.com/javafx/11.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.ResultVaultController"
            styleClass="dashboard-background">

    <left>
        <VBox spacing="18"
              prefWidth="230"
              styleClass="admin-sidebar">

            <children>
                <VBox spacing="3">
                    <children>
                        <Label text="SANTÉ"
                               styleClass="sidebar-brand-title" />
                        <Label text="DIAGNOSTICS LIMS"
                               styleClass="sidebar-brand-subtitle" />
                    </children>
                </VBox>

                <Region prefHeight="18" />

                <Button text="Dashboard"
                        onAction="#backToDashboard"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="View Available Tests"
                        onAction="#openTestCatalogue"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="View My Requests"
                        onAction="#openMyRequests"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Open Result Vault"
                        onAction="#openResultVault"
                        prefWidth="198"
                        styleClass="sidebar-menu-button-active" />

                <Region VBox.vgrow="ALWAYS" />

                <Button text="Logout"
                        onAction="#handleLogout"
                        prefWidth="198"
                        styleClass="admin-logout-button" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox spacing="20"
              alignment="CENTER_LEFT"
              styleClass="top-bar">
            <children>
                <Label text="Result Vault"
                       styleClass="dashboard-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="← Back to Dashboard"
                        onAction="#backToDashboard"
                        styleClass="back-dashboard-button" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox styleClass="customer-main-area">
            <children>
                <VBox spacing="12"
                      styleClass="customer-content-card">
                    <children>
                        <Label text="Validated Results"
                               styleClass="customer-section-title" />

                        <Label text="Only released or validated laboratory results should appear here."
                               styleClass="customer-section-text" />

                        <TableView fx:id="resultsTable"
                                   prefWidth="820"
                                   prefHeight="300">
                            <columns>
                                <TableColumn fx:id="testNameColumn" text="Test Name" prefWidth="220" />
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="140" />
                                <TableColumn fx:id="pdfColumn" text="PDF Report" prefWidth="200" />
                                <TableColumn fx:id="imageColumn" text="Medical Image" prefWidth="200" />
                            </columns>
                        </TableView>

                        <HBox spacing="12">
                            <children>
                                <Button text="View PDF Report"
                                        onAction="#viewPdfReport"
                                        prefWidth="150"
                                        styleClass="primary-button" />

                                <Button text="Download PDF"
                                        onAction="#downloadPdfReport"
                                        prefWidth="140"
                                        styleClass="secondary-button" />

                                <Button text="View Medical Image"
                                        onAction="#viewMedicalImage"
                                        prefWidth="170"
                                        styleClass="secondary-button" />

                                <Button text="Download Image"
                                        onAction="#downloadMedicalImage"
                                        prefWidth="150"
                                        styleClass="secondary-button" />
                            </children>
                        </HBox>

                        <Label fx:id="messageLabel"
                               text="Only validated laboratory results will appear here."
                               styleClass="customer-section-text" />
                    </children>
                </VBox>

                <VBox spacing="8"
                      styleClass="customer-note-card">
                    <children>
                        <Label text="Vault Information"
                               styleClass="customer-note-title" />
                        <Label text="This section is for customer access to validated reports only. Draft or unvalidated reports should not appear here."
                               styleClass="customer-note-text" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

</BorderPane>