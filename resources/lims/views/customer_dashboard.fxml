<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1100.0"
            prefHeight="650.0"
            xmlns="http://javafx.com/javafx/11.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.CustomerDashboardController"
            styleClass="dashboard-background">

    <left>
        <VBox spacing="18"
              prefWidth="230"
              styleClass="admin-sidebar">

            <children>
                <VBox spacing="3">
                    <children>
                        <Label text="SANTÉ"
                               styleClass="sidebar-brand-title" />
                        <Label text="DIAGNOSTICS LIMS"
                               styleClass="sidebar-brand-subtitle" />
                    </children>
                </VBox>

                <Region prefHeight="18" />

                <Button text="Dashboard"
                        prefWidth="198"
                        styleClass="sidebar-menu-button-active" />

                <Button text="View Available Tests"
                        onAction="#openTestCatalogue"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="View My Requests"
                        onAction="#openMyRequests"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Open Result Vault"
                        onAction="#openResultVault"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Region VBox.vgrow="ALWAYS" />

                <Button text="Logout"
                        onAction="#handleLogout"
                        prefWidth="198"
                        styleClass="admin-logout-button" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox spacing="20"
              alignment="CENTER_LEFT"
              styleClass="top-bar">
            <children>
                <Label text="Customer Dashboard"
                       styleClass="dashboard-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="Customer Portal"
                       styleClass="welcome-label" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox styleClass="customer-main-area">

            <children>
                <VBox spacing="8"
                      styleClass="customer-hero-card">
                    <children>
                        <Label fx:id="welcomeLabel"
                               text="Welcome, Customer"
                               styleClass="customer-hero-title" />

                        <Label text="Use this dashboard to browse tests, track your requests, and access validated results."
                               styleClass="customer-hero-subtitle" />

                        <Button text="Browse Available Tests"
                                onAction="#openTestCatalogue"
                                prefWidth="220"
                                styleClass="primary-button" />
                    </children>
                </VBox>

                <HBox spacing="18">
                    <children>
                        <VBox prefWidth="190"
                              spacing="8"
                              styleClass="customer-stat-card">
                            <children>
                                <Label text="TOTAL REQUESTS"
                                       styleClass="customer-stat-title" />
                                <Label text="12"
                                       styleClass="customer-stat-number" />
                                <Label text="All submissions"
                                       styleClass="customer-stat-note" />
                            </children>
                        </VBox>

                        <VBox prefWidth="190"
                              spacing="8"
                              styleClass="customer-stat-card">
                            <children>
                                <Label text="IN PROGRESS"
                                       styleClass="customer-stat-title" />
                                <Label text="3"
                                       styleClass="customer-stat-number" />
                                <Label text="Currently processing"
                                       styleClass="customer-stat-note" />
                            </children>
                        </VBox>

                        <VBox prefWidth="190"
                              spacing="8"
                              styleClass="customer-stat-card">
                            <children>
                                <Label text="READY RESULTS"
                                       styleClass="customer-stat-title" />
                                <Label text="2"
                                       styleClass="customer-stat-number" />
                                <Label text="Validated reports"
                                       styleClass="customer-stat-note" />
                            </children>
                        </VBox>

                        <VBox prefWidth="190"
                              spacing="8"
                              styleClass="customer-stat-card">
                            <children>
                                <Label text="UNPAID"
                                       styleClass="customer-stat-title" />
                                <Label text="1"
                                       styleClass="customer-stat-number" />
                                <Label text="Pending payment"
                                       styleClass="customer-stat-note" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="10"
                      styleClass="customer-content-card">
                    <children>
                        <Label text="Quick Access"
                               styleClass="customer-section-title" />

                        <Label text="You can browse available tests, monitor request progress, and download validated laboratory reports from here."
                               styleClass="customer-section-text" />

                        <HBox spacing="14">
                            <children>
                                <Button text="Browse Tests"
                                        onAction="#openTestCatalogue"
                                        prefWidth="170"
                                        styleClass="primary-button" />

                                <Button text="My Requests"
                                        onAction="#openMyRequests"
                                        prefWidth="170"
                                        styleClass="secondary-button" />

                                <Button text="Result Vault"
                                        onAction="#openResultVault"
                                        prefWidth="170"
                                        styleClass="secondary-button" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

</BorderPane>