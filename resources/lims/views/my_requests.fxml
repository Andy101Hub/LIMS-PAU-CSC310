<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1150.0"
            prefHeight="650.0"
            xmlns="http://javafx.com/javafx/11.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.MyRequestsController"
            styleClass="dashboard-background">

    <left>
        <VBox spacing="18"
              prefWidth="230"
              styleClass="admin-sidebar">

            <children>
                <VBox spacing="3">
                    <children>
                        <Label text="SANTÉ"
                               styleClass="sidebar-brand-title" />
                        <Label text="DIAGNOSTICS LIMS"
                               styleClass="sidebar-brand-subtitle" />
                    </children>
                </VBox>

                <Region prefHeight="18" />

                <Button text="Dashboard"
                        onAction="#backToDashboard"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="View Available Tests"
                        onAction="#openTestCatalogue"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="View My Requests"
                        onAction="#openMyRequests"
                        prefWidth="198"
                        styleClass="sidebar-menu-button-active" />

                <Button text="Open Result Vault"
                        onAction="#openResultVault"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Region VBox.vgrow="ALWAYS" />

                <Button text="Logout"
                        onAction="#handleLogout"
                        prefWidth="198"
                        styleClass="admin-logout-button" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox spacing="20"
              alignment="CENTER_LEFT"
              styleClass="top-bar">
            <children>
                <Label text="My Requests"
                       styleClass="dashboard-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="← Back to Dashboard"
                        onAction="#backToDashboard"
                        styleClass="back-dashboard-button" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox styleClass="customer-main-area">
            <children>
                <VBox spacing="12"
                      styleClass="customer-content-card">
                    <children>
                        <Label text="Track Your Test Requests"
                               styleClass="customer-section-title" />

                        <Label text="Monitor request status, payment progress, and estimated readiness from the table below."
                               styleClass="customer-section-text" />

                        <TableView fx:id="requestsTable"
                                   prefWidth="860"
                                   prefHeight="350">
                            <columns>
                                <TableColumn fx:id="requestIdColumn" text="Request ID" prefWidth="90" />
                                <TableColumn fx:id="testNameColumn" text="Test Name" prefWidth="190" />
                                <TableColumn fx:id="paymentStatusColumn" text="Payment Status" prefWidth="140" />
                                <TableColumn fx:id="requestStatusColumn" text="Request Status" prefWidth="160" />
                                <TableColumn fx:id="requestedAtColumn" text="Requested At" prefWidth="170" />
                                <TableColumn fx:id="countdownColumn" text="Countdown" prefWidth="170" />
                            </columns>
                        </TableView>

                        <Label fx:id="messageLabel"
                               text=""
                               styleClass="error-label" />
                    </children>
                </VBox>

                <VBox spacing="8"
                      styleClass="customer-note-card">
                    <children>
                        <Label text="Tip"
                               styleClass="customer-note-title" />
                        <Label text="Requests that are validated or completed will be available inside the Result Vault."
                               styleClass="customer-note-text" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

</BorderPane>