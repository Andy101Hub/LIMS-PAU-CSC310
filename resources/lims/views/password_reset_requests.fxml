<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="1150.0"
            prefHeight="650.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lims.controllers.PasswordResetRequestsController"
            styleClass="dashboard-background">

    <left>
        <VBox spacing="18"
              prefWidth="230"
              styleClass="admin-sidebar">

            <children>
                <VBox spacing="3">
                    <children>
                        <Label text="SANTÉ"
                               styleClass="sidebar-brand-title" />
                        <Label text="DIAGNOSTICS LIMS"
                               styleClass="sidebar-brand-subtitle" />
                    </children>
                </VBox>

                <Region prefHeight="18" />

                <Button text="Dashboard"
                        onAction="#goBackToDashboard"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="User Management"
                        onAction="#openUserManagement"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Custom Test Builder"
                        onAction="#openTestBuilder"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Test Request Queue"
                        onAction="#openTestRequestQueue"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Password Reset Requests"
                        onAction="#openPasswordResetRequests"
                        prefWidth="198"
                        styleClass="sidebar-menu-button-active" />

                <Button text="Audit Trail"
                        onAction="#openAuditTrail"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Region VBox.vgrow="ALWAYS" />

                <Button text="Logout"
                        onAction="#handleLogout"
                        prefWidth="198"
                        styleClass="admin-logout-button" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox spacing="20"
              alignment="CENTER_LEFT"
              styleClass="top-bar">

            <children>
                <Label text="Password Reset Requests"
                       styleClass="dashboard-title" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="← Back to Dashboard"
                        onAction="#goBackToDashboard"
                        styleClass="back-dashboard-button" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="18"
              styleClass="admin-main-area">

            <children>
                <VBox spacing="8"
                      styleClass="admin-hero-card">
                    <children>
                        <Label text="Lab Attendant Password Reset"
                               styleClass="admin-hero-title" />

                        <Label text="Review pending Lab Attendant password reset requests and issue temporary passwords."
                               wrapText="true"
                               styleClass="admin-hero-subtitle" />
                    </children>
                </VBox>

                <VBox spacing="15"
                      styleClass="table-card">

                    <children>
                        <Label text="Pending Reset Requests"
                               styleClass="section-heading" />

                        <TableView fx:id="resetTable"
                                   prefWidth="850"
                                   prefHeight="310">

                            <columns>
                                <TableColumn fx:id="requestIdColumn"
                                             text="Request ID"
                                             prefWidth="90" />

                                <TableColumn fx:id="emailColumn"
                                             text="Email"
                                             prefWidth="230" />

                                <TableColumn fx:id="roleColumn"
                                             text="Role"
                                             prefWidth="150" />

                                <TableColumn fx:id="statusColumn"
                                             text="Status"
                                             prefWidth="130" />

                                <TableColumn fx:id="requestedAtColumn"
                                             text="Requested At"
                                             prefWidth="220" />
                            </columns>
                        </TableView>

                        <VBox spacing="6">
                            <children>
                                <Label text="Temporary Password"
                                       styleClass="input-label" />

                                <PasswordField fx:id="temporaryPasswordField"
                                               promptText="Enter temporary password"
                                               prefWidth="360"
                                               styleClass="auth-input" />
                            </children>
                        </VBox>

                        <HBox spacing="15"
                              alignment="CENTER_LEFT">
                            <children>
                                <Button text="Set Temporary Password"
                                        onAction="#handleSetTemporaryPassword"
                                        prefWidth="230"
                                        styleClass="primary-button" />

                                <Button text="Refresh"
                                        onAction="#handleRefresh"
                                        prefWidth="140"
                                        styleClass="secondary-button" />
                            </children>
                        </HBox>

                        <Label fx:id="messageLabel"
                               text=""
                               wrapText="true"
                               styleClass="error-label" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>

</BorderPane>