<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="lims.controllers.TestRequestQueueController"
            prefWidth="1000"
            prefHeight="650"
            styleClass="dashboard-background">

    <top>
        <HBox spacing="20"
              styleClass="top-bar">

            <children>
                <Label text="Super Admin Test Request Queue"
                       styleClass="dashboard-title" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="15"
              styleClass="table-card">

            <children>

                <Label text="Customer Test Requests"
                       styleClass="section-heading" />

                <TableView fx:id="requestTable"
                           prefWidth="900"
                           prefHeight="400">

                    <columns>
                        <TableColumn fx:id="requestIdColumn"
                                     text="Request ID"
                                     prefWidth="80" />

                        <TableColumn fx:id="customerNameColumn"
                                     text="Customer Name"
                                     prefWidth="150" />

                        <TableColumn fx:id="customerEmailColumn"
                                     text="Customer Email"
                                     prefWidth="190" />

                        <TableColumn fx:id="testNameColumn"
                                     text="Test Name"
                                     prefWidth="170" />

                        <TableColumn fx:id="paymentStatusColumn"
                                     text="Payment"
                                     prefWidth="100" />

                        <TableColumn fx:id="requestStatusColumn"
                                     text="Status"
                                     prefWidth="140" />

                        <TableColumn fx:id="requestedAtColumn"
                                     text="Requested At"
                                     prefWidth="160" />
                    </columns>
                </TableView>

                <Label fx:id="messageLabel"
                       text=""
                       styleClass="error-label" />

                <HBox spacing="15">
                    <children>
                        <Button text="Refresh"
                                onAction="#handleRefresh"
                                prefWidth="160"
                                styleClass="menu-button" />

                        <Button text="Mark Selected as Paid"
                                onAction="#handleMarkAsPaid"
                                prefWidth="200"
                                styleClass="primary-button" />

                        <Button text="Back to Dashboard"
                                onAction="#goBackToDashboard"
                                prefWidth="180"
                                styleClass="menu-button" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </center>

</BorderPane>