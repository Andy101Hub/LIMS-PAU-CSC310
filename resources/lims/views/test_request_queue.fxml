<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="lims.controllers.TestRequestQueueController"
            prefWidth="1100"
            prefHeight="650"
            styleClass="dashboard-background">

    <left>
        <VBox spacing="18"
              prefWidth="230"
              styleClass="admin-sidebar">

            <children>
                <VBox spacing="3">
                    <children>
                        <Label text="SANTÉ"
                               styleClass="sidebar-brand-title" />

                        <Label text="DIAGNOSTICS LIMS"
                               styleClass="sidebar-brand-subtitle" />
                    </children>
                </VBox>

                <Region prefHeight="18" />

                <Button text="Dashboard"
                        onAction="#goBackToDashboard"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="User Management"
                        onAction="#openUserManagement"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Custom Test Builder"
                        onAction="#openTestBuilder"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Button text="Test Request Queue"
                        onAction="#openTestRequestQueue"
                        prefWidth="198"
                        styleClass="sidebar-menu-button-active" />

                <Button text="Audit Trail"
                        onAction="#openAuditTrail"
                        prefWidth="198"
                        styleClass="sidebar-menu-button" />

                <Region VBox.vgrow="ALWAYS" />

                <Button text="Logout"
                        onAction="#handleLogout"
                        prefWidth="198"
                        styleClass="admin-logout-button" />
            </children>
        </VBox>
    </left>

    <top>
        <HBox spacing="20"
              alignment="CENTER_LEFT"
              styleClass="top-bar">

            <children>
                <Label text="Super Admin Test Request Queue"
                       styleClass="dashboard-title" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="← Back to Dashboard"
                        onAction="#goBackToDashboard"
                        styleClass="back-dashboard-button" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="15"
              styleClass="table-card">

            <children>

                <Label text="Customer Test Requests"
                       styleClass="section-heading" />

                <TableView fx:id="requestTable"
                           prefWidth="840"
                           prefHeight="400">

                    <columns>
                        <TableColumn fx:id="requestIdColumn"
                                     text="Request ID"
                                     prefWidth="70" />

                        <TableColumn fx:id="customerNameColumn"
                                     text="Customer Name"
                                     prefWidth="125" />

                        <TableColumn fx:id="customerEmailColumn"
                                     text="Customer Email"
                                     prefWidth="170" />

                        <TableColumn fx:id="testNameColumn"
                                     text="Test Name"
                                     prefWidth="140" />

                        <TableColumn fx:id="paymentStatusColumn"
                                     text="Payment"
                                     prefWidth="90" />

                        <TableColumn fx:id="requestStatusColumn"
                                     text="Status"
                                     prefWidth="110" />

                        <TableColumn fx:id="requestedAtColumn"
                                     text="Requested At"
                                     prefWidth="135" />
                    </columns>
                </TableView>

                <Label fx:id="messageLabel"
                       text=""
                       styleClass="error-label" />

                <HBox spacing="15"
                      alignment="CENTER_LEFT">
                    <children>
                        <Button text="Refresh"
                                onAction="#handleRefresh"
                                prefWidth="160"
                                styleClass="menu-button" />

                        <Button text="Mark Selected as Paid"
                                onAction="#handleMarkAsPaid"
                                prefWidth="200"
                                styleClass="primary-button" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </center>

</BorderPane>