<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="lims.controllers.ForcePasswordChangeController"
            prefWidth="500"
            prefHeight="420"
            styleClass="login-background">

    <children>
        <VBox alignment="CENTER"
              spacing="15"
              layoutX="100"
              layoutY="50"
              prefWidth="300"
              prefHeight="320"
              styleClass="login-card">

            <children>

                <Label text="Change Password"
                       styleClass="title-label" />

                <Label text="You must change your password before continuing."
                       wrapText="true"
                       styleClass="normal-text" />

                <PasswordField fx:id="newPasswordField"
                               promptText="Enter New Password"
                               prefWidth="250" />

                <PasswordField fx:id="confirmPasswordField"
                               promptText="Confirm New Password"
                               prefWidth="250" />

                <Label fx:id="messageLabel"
                       text=""
                       styleClass="error-label" />

                <Button text="Update Password"
                        onAction="#handlePasswordChange"
                        prefWidth="250"
                        styleClass="primary-button" />

            </children>
        </VBox>
    </children>
</AnchorPane>