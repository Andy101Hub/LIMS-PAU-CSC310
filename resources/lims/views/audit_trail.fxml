<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="lims.controllers.AuditTrailController"
            prefWidth="1000"
            prefHeight="650"
            styleClass="dashboard-background">

    <top>
        <HBox spacing="20"
              styleClass="top-bar">

            <children>
                <Label text="Audit Trail"
                       styleClass="dashboard-title" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="15"
              styleClass="table-card">

            <children>

                <Label text="System Activity Logs"
                       styleClass="section-heading" />

                <TableView fx:id="auditTable"
                           prefWidth="900"
                           prefHeight="430">

                    <columns>
                        <TableColumn fx:id="auditIdColumn"
                                     text="ID"
                                     prefWidth="60" />

                        <TableColumn fx:id="userNameColumn"
                                     text="User"
                                     prefWidth="150" />

                        <TableColumn fx:id="userEmailColumn"
                                     text="Email"
                                     prefWidth="180" />

                        <TableColumn fx:id="actionColumn"
                                     text="Action"
                                     prefWidth="170" />

                        <TableColumn fx:id="detailsColumn"
                                     text="Details"
                                     prefWidth="250" />

                        <TableColumn fx:id="createdAtColumn"
                                     text="Date/Time"
                                     prefWidth="160" />
                    </columns>
                </TableView>

                <Label fx:id="messageLabel"
                       text=""
                       styleClass="error-label" />

                <HBox spacing="15">
                    <children>
                        <Button text="Refresh"
                                onAction="#handleRefresh"
                                prefWidth="160"
                                styleClass="menu-button" />

                        <Button text="Back to Dashboard"
                                onAction="#goBackToDashboard"
                                prefWidth="180"
                                styleClass="menu-button" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </center>

</BorderPane>